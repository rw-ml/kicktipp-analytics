# Kicktipp-Zugangsdaten (eines Mitspielers, nicht öffentlich teilen!)
KICKTIPP_USERNAME=dein-benutzername
KICKTIPP_PASSWORD=dein-passwort
KICKTIPP_COMMUNITY_URL=https://www.kicktipp.de/eure-wm-runde/

SEASON=wm2026

# Mindestens eine der beiden folgenden Variablen setzen - beide gleichzeitig
# sind möglich und sinnvoll, wenn sowohl Power BI Desktop (z.B. via CSV) als
# auch Power BI Pro/Premium mit Gateway (zentrale DB) bedient werden sollen.

# Für PostgreSQL auf dem eigenen Server:
SQL_CONNECTION_URL=postgresql+psycopg2://user:password@localhost:5432/kicktipp

# Für eine lokale SQLite-Datei (z.B. zum Testen):
# SQL_CONNECTION_URL=sqlite:///kicktipp.db

# Für CSV-Export (z.B. für Power BI Desktop ohne DB-Treiber):
# CSV_OUTPUT_DIR=./output

# Playwright-Browser sichtbar laufen lassen (nützlich beim ersten Testlauf
# bzw. zum Verifizieren/Anpassen der Scraper-Selektoren):
HEADLESS_BROWSER=true
